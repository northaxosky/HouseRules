        {
            "pageDisplayName": "Character",
            "content": [
                {
                    "text": "<font size='24'><p align='center'>Character Feel</p></font>",
                    "html": true,
                    "type": "text"
                },
                {
                    "text": "<font color='#AAAAAA'><p align='center'>Action Points and sprint tuning. Multiplier sliders show 1.00 = vanilla; Direct sliders show the vanilla default as their neutral value.</p></font>",
                    "html": true,
                    "type": "text"
                },
                { "type": "spacer" },
                { "text": "Action Points", "type": "section" },
                {
                    "id": "fAPBaseMult:Character",
                    "text": "AP Pool Base",
                    "type": "slider",
                    "help": "Base AP pool. May need actor-value refresh.",
                    "valueOptions": { "min": 0.25, "max": 4.0, "step": 0.05, "sourceType": "ModSettingFloat" }
                },
                {
                    "id": "fAPPerAgilityMult:Character",
                    "text": "AP per Agility",
