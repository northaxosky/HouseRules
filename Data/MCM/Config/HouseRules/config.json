                    "id": "fIncomingDamageVeryEasy:Difficulty",
                    "text": "Incoming Damage (Very Easy)",
                    "type": "slider",
                    "help": "Scales fDiffMultHPToPCVE. 1.00 = vanilla.",
                    "valueOptions": { "min": 0.0, "max": 5.0, "step": 0.05, "sourceType": "ModSettingFloat" }
