{
    "$schema": "https://raw.githubusercontent.com/Neanka/mcm/master/doc/mcm.schema.json",
    "minMcmVersion": 2,
    "modName": "HouseRules",
    "displayName": "House Rules",
    "pluginRequirements": [],
    "content": [
        {
            "text": "<font size='30'><p align='center'>House Rules</p></font>",
            "html": true,
            "type": "text"
        },
        { "type": "spacer" },
        {
            "text": "<font color='#AAAAAA'><p align='center'>Selectively unlock vanilla Survival restrictions and tune the experience without losing Survival difficulty.</p></font>",
            "html": true,
            "type": "text"
        },
        { "type": "spacer", "numLines": 2 },
        {
            "text": "General",
            "type": "section"
        },
        {
            "id": "bEnabled:General",
            "text": "Enable Plugin",
            "type": "switcher",
            "help": "Master on/off. When OFF, every unlock and magnitude tweak falls back to vanilla Survival behavior. Dev-only diagnostics remain controlled separately via settings.ini.",
            "valueOptions": { "sourceType": "ModSettingBool" }
        }
    ],
    "pages": [
        {
            "pageDisplayName": "Unlocks",
            "content": [
                {
                    "text": "<font size='24'><p align='center'>Survival Unlocks</p></font>",
                    "html": true,
                    "type": "text"
                },
                {
                    "text": "<font color='#AAAAAA'><p align='center'>Each toggle: OFF mirrors vanilla Survival, ON applies the tweak.</p></font>",
                    "html": true,
                    "type": "text"
                },
                { "type": "spacer" },
                {
                    "text": "Menus & Saves",
                    "type": "section"
                },
                {
                    "id": "bConsole:Unlocks",
                    "text": "Allow Console",
                    "type": "switcher",
                    "help": "ON re-enables the developer console while in Survival.",
                    "valueOptions": { "sourceType": "ModSettingBool" }
                },
                {
                    "id": "bSaveSelf:Unlocks",
                    "text": "Allow Manual Saves",
                    "type": "switcher",
                    "help": "ON re-enables F5 quicksave and the pause-menu Save/Load surfaces in Survival.",
                    "valueOptions": { "sourceType": "ModSettingBool" }
                },
                {
                    "id": "bSaveAuto:Unlocks",
                    "text": "Allow Auto-Saves",
                    "type": "switcher",
                    "help": "ON re-enables queued vanilla auto-saves, including menu-close and door-arrival paths where the game requests them.",
                    "valueOptions": { "sourceType": "ModSettingBool" }
                },
                { "type": "spacer" },
                {
                    "text": "Travel & Exploration",
                    "type": "section"
                },
                {
                    "id": "bFastTravel:Unlocks",
                    "text": "Allow Fast Travel",
                    "type": "switcher",
                    "help": "ON re-enables Pip-Boy fast travel in Survival by spoofing the vanilla UI/eligibility checks. Fast-travel load screens use targeted HP/rads/rad-resistance protection; ordinary door/cell loads are not touched, and God Mode / Immortal Mode is not enabled.",
                    "valueOptions": { "sourceType": "ModSettingBool" }
                },
                {
                    "id": "bCompassEnemies:Unlocks",
                    "text": "Show Enemies on Compass",
                    "type": "switcher",
                    "help": "ON restores vanilla red-dot enemy markers on the compass.",
                    "valueOptions": { "sourceType": "ModSettingBool" }
                },
                {
                    "id": "bCompassLocations:Unlocks",
                    "text": "Show Locations on Compass",
                    "type": "switcher",
                    "help": "ON restores vanilla undiscovered-location markers on the compass.",
                    "valueOptions": { "sourceType": "ModSettingBool" }
                },
                { "type": "spacer" },
                {
                    "text": "Weight & Difficulty",
                    "type": "section"
                },
                {
                    "id": "bNoAlchWeight:Unlocks",
                    "text": "Remove Chem/Aid Weight",
                    "type": "switcher",
                    "help": "ON strips Survival's added weight from consumables (chems, stimpaks, food).",
                    "valueOptions": { "sourceType": "ModSettingBool" }
                },
                {
                    "id": "bNoAmmoWeight:Unlocks",
                    "text": "Remove Ammo Weight",
                    "type": "switcher",
                    "help": "ON strips Survival's added weight from ammunition.",
                    "valueOptions": { "sourceType": "ModSettingBool" }
                },
                {
                    "id": "bNoSurvivalCarryWeight:Unlocks",
                    "text": "Remove Survival Carry-Weight Penalty",
                    "type": "switcher",
                    "help": "ON neutralizes the -100 carry-weight ability Survival applies to the player, companions, and Dogmeat. Verified ESP-backed toggle; requires HouseRules.esp enabled and takes effect on the next pause-menu close.",
                    "valueOptions": { "sourceType": "ModSettingBool" }
                },
                {
                    "id": "bGodMode:Unlocks",
                    "text": "Allow God Mode",
                    "type": "switcher",
                    "help": "ON lets the tgm and tim console cheats take effect in Survival (damage is blocked while the cheat is active).",
                    "valueOptions": { "sourceType": "ModSettingBool" }
                },
                {
                    "id": "bReenableSurvival:Unlocks",
                    "text": "Allow Re-entering Survival",
                    "type": "switcher",
                    "help": "ON removes vanilla's one-way gate so you can switch Survival on and off freely. Live-toggleable via MCM.",
                    "valueOptions": { "sourceType": "ModSettingBool" }
                }
            ]
        },
        {
            "pageDisplayName": "Magnitudes",
            "content": [
                {
                    "text": "<font size='24'><p align='center'>Magnitude Scalers</p></font>",
                    "html": true,
                    "type": "text"
                },
                {
                    "text": "<font color='#AAAAAA'><p align='center'>Implemented sliders multiply proven vanilla magnitudes. 1.00 = vanilla; see each setting for caveats.</p></font>",
                    "html": true,
                    "type": "text"
                },
                { "type": "spacer" },
                { "text": "Consumables", "type": "section" },
                {
                    "id": "fStimpakHeal:Magnitudes",
                    "text": "Stimpak Healing",
                    "type": "slider",
                    "help": "Scales the HP restored per stimpak. Vanilla magnitude is 6 HP/sec over 5s.",
                    "valueOptions": { "min": 0.0, "max": 5.0, "step": 0.1, "sourceType": "ModSettingFloat" }
                },
                {
                    "id": "fStimpakLimbRepair:Magnitudes",
                    "text": "Stimpak Limb Repair",
                    "type": "slider",
                    "help": "Per-limb RestoreCondition strength (1.0 = vanilla full heal, 0.5 = heal half, 0 = keep limbs broken). Vanilla limb condition is clamped to max after a stimpak, so values above 1.0 have no effect.",
                    "valueOptions": { "min": 0.0, "max": 1.0, "step": 0.1, "sourceType": "ModSettingFloat" }
                },
                {
                    "id": "fRadAwayStrength:Magnitudes",
                    "text": "RadAway Removal",
                    "type": "slider",
                    "help": "Scales the rads removed per RadAway. Vanilla magnitude is 60.",
                    "valueOptions": { "min": 0.0, "max": 5.0, "step": 0.1, "sourceType": "ModSettingFloat" }
                },
                {
                    "id": "fRadXPotency:Magnitudes",
                    "text": "RadX Protection",
                    "type": "slider",
                    "help": "Scales the rad resistance granted by RadX. Vanilla magnitude is 100 over 180s.",
                    "valueOptions": { "min": 0.0, "max": 5.0, "step": 0.1, "sourceType": "ModSettingFloat" }
                },
                {
                    "id": "fFoodHeal:Magnitudes",
                    "text": "Food / Drink Healing",
                    "type": "slider",
                    "help": "Scales per-consumable RestoreHealthFood effect magnitudes. Changes apply to items you haven't eaten yet in the current session; the Pip-Boy tooltip may keep its cached number until the item is consumed or re-equipped.",
                    "valueOptions": { "min": 0.0, "max": 5.0, "step": 0.1, "sourceType": "ModSettingFloat" }
                },
                { "type": "spacer" },
                { "text": "Survival Stage Penalties", "type": "section" },
                {
                    "id": "fHungerPenalty:Magnitudes",
                    "text": "Hunger Penalty Severity",
                    "type": "slider",
                    "help": "Scales the SPECIAL penalties at each hunger tier (Peckish through Starving).",
                    "valueOptions": { "min": 0, "max": 5, "step": 1, "sourceType": "ModSettingFloat" }
                },
                {
                    "id": "fThirstPenalty:Magnitudes",
                    "text": "Thirst Penalty Severity",
                    "type": "slider",
                    "help": "Scales the SPECIAL penalties at each thirst tier (Thirsty through Severely Dehydrated).",
                    "valueOptions": { "min": 0, "max": 5, "step": 1, "sourceType": "ModSettingFloat" }
                },
                {
                    "id": "fSleepPenalty:Magnitudes",
                    "text": "Sleep Penalty Severity",
                    "type": "slider",
                    "help": "Scales the AP-regen and SPECIAL penalties at each sleep tier (Tired through Incapacitated).",
                    "valueOptions": { "min": 0, "max": 5, "step": 1, "sourceType": "ModSettingFloat" }
                }
            ]
        },
        {
            "pageDisplayName": "Difficulty",
            "content": [
                {
                    "text": "<font size='24'><p align='center'>Difficulty Multipliers</p></font>",
                    "html": true,
                    "type": "text"
                },
                {
                    "text": "<font color='#AAAAAA'><p align='center'>Per-difficulty multipliers applied as baseline * value. 1.00 = vanilla. Survival here is the current TSV difficulty.</p></font>",
                    "html": true,
                    "type": "text"
                },
                { "type": "spacer" },
                { "text": "Damage Taken", "type": "section" },
