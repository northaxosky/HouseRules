                    "text": "Legendary Chance (Very Easy)",
                    "type": "slider",
                    "help": "Scales fDiffMultLegendaryChance_VE. 1.00 = vanilla.",
                    "valueOptions": { "min": 0.0, "max": 10.0, "step": 0.05, "sourceType": "ModSettingFloat" }
                },
                {
