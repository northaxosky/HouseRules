                    "valueOptions": { "min": 0.0, "max": 5.0, "step": 0.05, "sourceType": "ModSettingFloat" }
                },
                { "type": "spacer" },
                { "text": "Progression", "type": "section" },
                {
                    "id": "fXPBase:Difficulty",
                    "text": "XP Base",
                    "type": "slider",
                    "help": "Scales fXPModBase, the flat XP grant component. 1.00 = vanilla.",
                    "valueOptions": { "min": 0.0, "max": 5.0, "step": 0.05, "sourceType": "ModSettingFloat" }
                },
                {
                    "id": "fXPMult:Difficulty",
                    "text": "XP Multiplier",
                    "type": "slider",
                    "help": "Scales fXPModMult, the difficulty-scaled XP multiplier. 1.00 = vanilla.",
                    "valueOptions": { "min": 0.0, "max": 5.0, "step": 0.05, "sourceType": "ModSettingFloat" }
                },
                { "type": "spacer" },
                { "text": "Legendary Chance", "type": "section" },
