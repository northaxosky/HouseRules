{
    "$schema": "https://raw.githubusercontent.com/Neanka/mcm/master/doc/mcm.schema.json",
    "modName": "Survival Architect",
    "displayName": "Survival Architect",
    "pluginRequirements": [],
    "content": [
        {
            "text": "General",
            "type": "section"
        },
        {
            "id": "bEnabled:General",
            "text": "Enable Plugin",
            "type": "toggle",
            "help": "Master on/off. When off, all unlocks and tweaks revert to vanilla.",
            "valueOptions": { "sourceType": "ModSettingBool" }
        },

        {
            "text": "Survival Unlocks",
            "type": "section"
        },
        {
            "id": "bConsole:Unlocks",
            "text": "Allow Console",
            "type": "toggle",
            "help": "Re-enable the developer console while in Survival.",
            "valueOptions": { "sourceType": "ModSettingBool" }
        },
        {
            "id": "bFastTravel:Unlocks",
            "text": "Allow Fast Travel",
            "type": "toggle",
            "help": "Re-enable fast travel while in Survival.",
            "valueOptions": { "sourceType": "ModSettingBool" }
        },
        {
            "id": "bGodMode:Unlocks",
            "text": "Allow God Mode",
            "type": "toggle",
            "help": "Re-enable the tgm/tdm console commands in Survival.",
            "valueOptions": { "sourceType": "ModSettingBool" }
        },
        {
            "id": "bSaveAuto:Unlocks",
            "text": "Allow Auto-Saves",
            "type": "toggle",
            "help": "Re-enable vanilla auto-saves while in Survival.",
            "valueOptions": { "sourceType": "ModSettingBool" }
        },
        {
            "id": "bSaveSelf:Unlocks",
            "text": "Allow Manual Saves",
            "type": "toggle",
            "help": "Re-enable F5 quicksave and the Save/Load menu while in Survival.",
            "valueOptions": { "sourceType": "ModSettingBool" }
        },
        {
            "id": "bSleepSave:Unlocks",
            "text": "Sleep-Save Enabled",
            "type": "toggle",
            "help": "Keep vanilla Survival's sleep-based save behaviour.",
            "valueOptions": { "sourceType": "ModSettingBool" }
        },
        {
            "id": "bCompassEnemies:Unlocks",
            "text": "Compass Shows Enemies",
            "type": "toggle",
            "help": "Re-enable red enemy dots on the compass.",
            "valueOptions": { "sourceType": "ModSettingBool" }
        },
        {
            "id": "bCompassLocations:Unlocks",
            "text": "Compass Shows Locations",
            "type": "toggle",
            "help": "Re-enable undiscovered-location markers on the compass.",
            "valueOptions": { "sourceType": "ModSettingBool" }
        },
        {
            "id": "bAlchWeight:Unlocks",
            "text": "Chems & Aid Have Weight",
            "type": "toggle",
            "help": "Keep vanilla Survival weight on consumables.",
            "valueOptions": { "sourceType": "ModSettingBool" }
        },
        {
            "id": "bAmmoWeight:Unlocks",
            "text": "Ammo Has Weight",
            "type": "toggle",
            "help": "Keep vanilla Survival weight on ammunition.",
            "valueOptions": { "sourceType": "ModSettingBool" }
        },
        {
            "id": "bLockSurvival:Unlocks",
            "text": "Lock Difficulty to Survival",
            "type": "toggle",
            "help": "Prevent changing difficulty away from Survival.",
            "valueOptions": { "sourceType": "ModSettingBool" }
        },

        {
            "text": "Need Rates",
            "type": "section"
        },
        {
            "id": "fHungerRate:NeedRates",
            "text": "Hunger Rate",
            "type": "slider",
            "help": "Multiplier on vanilla hunger rate. 0 disables hunger; 1 is vanilla.",
            "sliderOptions": { "min": 0.0, "max": 5.0, "step": 0.1 },
            "valueOptions": { "sourceType": "ModSettingFloat" }
        },
        {
            "id": "fThirstRate:NeedRates",
            "text": "Thirst Rate",
            "type": "slider",
            "help": "Multiplier on vanilla thirst rate. 0 disables thirst; 1 is vanilla.",
            "sliderOptions": { "min": 0.0, "max": 5.0, "step": 0.1 },
            "valueOptions": { "sourceType": "ModSettingFloat" }
        },
        {
            "id": "fSleepRate:NeedRates",
            "text": "Sleep Rate",
            "type": "slider",
            "help": "Multiplier on vanilla fatigue rate. 0 disables sleep need; 1 is vanilla.",
            "sliderOptions": { "min": 0.0, "max": 5.0, "step": 0.1 },
            "valueOptions": { "sourceType": "ModSettingFloat" }
        }
    ]
}
