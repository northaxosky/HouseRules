{
    "$schema": "https://raw.githubusercontent.com/Neanka/mcm/master/doc/mcm.schema.json",
    "minMcmVersion": 2,
    "modName": "SurvivalArchitect",
    "displayName": "Survival Architect",
    "pluginRequirements": [],
    "content": [
        {
            "text": "<font size='30'><p align='center'>Survival Architect</p></font>",
            "html": true,
            "type": "text"
        },
        { "type": "spacer" },
        {
            "text": "<font color='#AAAAAA'><p align='center'>Selectively unlock vanilla Survival restrictions and tune the experience without losing Survival difficulty.</p></font>",
            "html": true,
            "type": "text"
        },
        { "type": "spacer", "numLines": 2 },
        {
            "text": "General",
            "type": "section"
        },
        {
            "id": "bEnabled:General",
            "text": "Enable Plugin",
            "type": "switcher",
            "help": "Master on/off. When OFF, every unlock/tweak falls back to vanilla Survival behavior.",
            "valueOptions": { "sourceType": "ModSettingBool" }
        }
    ],
    "pages": [
        {
            "pageDisplayName": "Unlocks",
            "content": [
                {
                    "text": "<font size='24'><p align='center'>Survival Unlocks</p></font>",
                    "html": true,
                    "type": "text"
                },
                {
                    "text": "<font color='#AAAAAA'><p align='center'>Each toggle: OFF mirrors vanilla Survival, ON applies the tweak.</p></font>",
                    "html": true,
                    "type": "text"
                },
                { "type": "spacer" },
                {
                    "text": "Menus & Saves",
                    "type": "section"
                },
                {
                    "id": "bConsole:Unlocks",
                    "text": "Allow Console",
                    "type": "switcher",
                    "help": "ON re-enables the developer console while in Survival.",
                    "valueOptions": { "sourceType": "ModSettingBool" }
                },
                {
                    "id": "bSaveSelf:Unlocks",
                    "text": "Allow Manual Saves",
                    "type": "switcher",
                    "help": "ON re-enables F5 quicksave and the Save/Load menu entries in Survival.",
                    "valueOptions": { "sourceType": "ModSettingBool" }
                },
                {
                    "id": "bSaveAuto:Unlocks",
                    "text": "Allow Auto-Saves",
                    "type": "switcher",
                    "help": "ON re-enables vanilla auto-saves (menu-close autosaves, pause-menu autosave setting).",
                    "valueOptions": { "sourceType": "ModSettingBool" }
                },
                {
                    "id": "bSleepSave:Unlocks",
                    "text": "Disable Sleep-Save",
                    "type": "switcher",
                    "help": "ON stops Survival's sleep-as-save behavior (hook not yet implemented — v0.2).",
                    "valueOptions": { "sourceType": "ModSettingBool" }
                },
                { "type": "spacer" },
                {
                    "text": "Travel & Exploration",
                    "type": "section"
                },
                {
                    "id": "bFastTravel:Unlocks",
                    "text": "Allow Fast Travel",
                    "type": "switcher",
                    "help": "ON re-enables fast travel from the Pipboy map while in Survival.",
                    "valueOptions": { "sourceType": "ModSettingBool" }
                },
                {
                    "id": "bCompassEnemies:Unlocks",
                    "text": "Show Enemies on Compass",
                    "type": "switcher",
                    "help": "ON restores vanilla red-dot enemy markers on the compass.",
                    "valueOptions": { "sourceType": "ModSettingBool" }
                },
                {
                    "id": "bCompassLocations:Unlocks",
                    "text": "Show Locations on Compass",
                    "type": "switcher",
                    "help": "ON restores vanilla undiscovered-location markers on the compass.",
                    "valueOptions": { "sourceType": "ModSettingBool" }
                },
                { "type": "spacer" },
                {
                    "text": "Weight & Difficulty",
                    "type": "section"
                },
                {
                    "id": "bNoAlchWeight:Unlocks",
                    "text": "Remove Chem/Aid Weight",
                    "type": "switcher",
                    "help": "ON strips Survival's added weight from consumables (chems, stimpaks, food).",
                    "valueOptions": { "sourceType": "ModSettingBool" }
                },
                {
                    "id": "bNoAmmoWeight:Unlocks",
                    "text": "Remove Ammo Weight",
                    "type": "switcher",
                    "help": "ON strips Survival's added weight from ammunition.",
                    "valueOptions": { "sourceType": "ModSettingBool" }
                },
                {
                    "id": "bGodMode:Unlocks",
                    "text": "Allow God Mode",
                    "type": "switcher",
                    "help": "ON re-enables tgm/tdm console commands in Survival (hook not yet implemented — v0.2).",
                    "valueOptions": { "sourceType": "ModSettingBool" }
                },
                {
                    "id": "bLockSurvival:Unlocks",
                    "text": "Lock Difficulty to Survival",
                    "type": "switcher",
                    "help": "ON prevents changing difficulty away from Survival (hook not yet implemented — v0.2).",
                    "valueOptions": { "sourceType": "ModSettingBool" }
                }
            ]
        }
    ]
}
